# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6375

# ── FastAPI ──────────────────────────────────────────────────────────────────
API_PORT=8001
SESSION_TTL_SECONDS=86400
SESSION_PREFIX=session:
COOKIE_SECURE=false

# ── Celery ───────────────────────────────────────────────────────────────────
CELERY_LOG_LEVEL=info
CELERY_CONCURRENCY=2

# ── LLM — Ollama (default) ───────────────────────────────────────────────────
SMART_LLM=ollama:qwen2.5:7b-instruct
FAST_LLM=ollama:llama3.2
OLLAMA_ENDPOINTS=["http://ollama:11434"]

# Used by ollama-pull service (strip the "ollama:" prefix)
SMART_LLM_MODEL=ollama:qwen2.5-coder:7b #qwen2.5:7b-instruct
FAST_LLM_MODEL=llama3.2

# ── LLM — Cloud alternative ──────────────────────────────────────────────────
# SMART_LLM=anthropic:claude-sonnet-4-20250514
# FAST_LLM=anthropic:claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=sk-ant-...

# SMART_LLM=openai:gpt-4o
# FAST_LLM=openai:gpt-4o-mini
# OPENAI_API_KEY=sk-...

# ── LLM shared ───────────────────────────────────────────────────────────────
TEMPERATURE=0.3
MAX_TOKENS=5000
MAX_REWRITE_ATTEMPTS=3

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DNS=postgresql://user:password@localhost:5432/resumatch
